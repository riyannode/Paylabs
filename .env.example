# PayLabs
# Copy to .env.local and fill real values. Never commit .env.local.
# Production: all x402 flags must be true. Missing vars = 500 config_error.

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_PAYLABS_APP_URL=http://localhost:3000
PAYLABS_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Arc Testnet ──────────────────────────────────────────
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Delegated Runtime (required) ─────────────────────────
PAYLABS_DELEGATED_RUNTIME_ENABLED=true
PAYLABS_DELEGATED_INLINE_EXECUTION=true

# ─── x402 Feature Flags (required for production) ─────────
PAYLABS_AGENT_NANOPAYMENTS_ENABLED=true
PAYLABS_BRAIN_X402_ENABLED=true
PAYLABS_NODE_X402_ENABLED=true
PAYLABS_X402_ENABLED_SERVICE_NAMES=all

# ─── Circle Gateway x402 ─────────────────────────────────
X402_GATEWAY_ENABLED=true
X402_GATEWAY_NETWORK=arc-testnet
X402_RECEIVER_ADDRESS=
CIRCLE_GATEWAY_API_KEY=

# ─── Entry Payment Wallets (required) ─────────────────────
PAYLABS_ENTRY_PAYMENT_SELLER_WALLET_ADDRESS=
PAYLABS_CONTROLLER_BUYER_WALLET_ID=

# ─── Brain Wallets (required) ─────────────────────────────
PAYLABS_BRAIN_BUYER_WALLET_ID=
PAYLABS_BRAIN_SELLER_WALLET_ADDRESS=

# ─── Macro-Node Buyer Wallets (required per tier) ─────────
# easy tier: discovery_planner only
# normal tier: + payment_decision
# advanced tier: + settlement_memory
PAYLABS_NODE_DISCOVERY_PLANNER_BUYER_WALLET_ID=
PAYLABS_NODE_DISCOVERY_PLANNER_SELLER_WALLET_ADDRESS=
PAYLABS_NODE_PAYMENT_DECISION_BUYER_WALLET_ID=
PAYLABS_NODE_PAYMENT_DECISION_SELLER_WALLET_ADDRESS=
PAYLABS_NODE_SETTLEMENT_MEMORY_BUYER_WALLET_ID=
PAYLABS_NODE_SETTLEMENT_MEMORY_SELLER_WALLET_ADDRESS=

# ─── Creator Distribution (PR #52) ─────────────────────
PAYLABS_CREATOR_PAYOUT_BUYER_WALLET_ID=
PAYLABS_SETTLEMENT_TREASURY_WALLET_ID=
PAYLABS_BOT_REVENUE_WALLET_ADDRESS=
PAYLABS_SERVICE_REVENUE_WALLET_ADDRESS=

# ─── Service Seller Wallets (required for child services) ─
PAYLABS_SERVICE_INTENT_PLANNER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_QUERY_BUILDER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_SIGNAL_SCOUT_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_INTENT_MATCHER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_SOURCE_VERIFIER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_VALUE_ALLOCATOR_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_TRUST_VERIFIER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_PAYMENT_DECIDER_SELLER_WALLET_ADDRESS=
PAYLABS_SERVICE_PAYMENT_ROUTER_SELLER_WALLET_ADDRESS=

# ─── LLM Config ──────────────────────────────────────────
PAYLABS_LLM_REQUIRED=true

# 9Router / OpenAI-compatible provider config
PAYLABS_LLM_PROVIDER_DEFAULT=openai-compatible
PAYLABS_LLM_BASE_URL_DEFAULT=
PAYLABS_LLM_API_KEY_DEFAULT=
PAYLABS_TUTOR_MODEL_DEFAULT=
PAYLABS_LLM_STREAMING_DEFAULT=false

# Optional legacy fallback
PAYLABS_OPENAI_API_KEY=
OPENAI_API_KEY=
PAYLABS_TUTOR_MODEL=

# Current agent keys (delegated runtime services):
#   intent_planner, query_builder, signal_scout, intent_matcher,
#   source_verifier, value_allocator, trust_verifier,
#   payment_decider, payment_router
#
# Optional per-agent overrides (uncomment and fill to route specific agents differently)
# PAYLABS_LLM_PROVIDER_INTENT_PLANNER=
# PAYLABS_LLM_BASE_URL_INTENT_PLANNER=
# PAYLABS_LLM_API_KEY_INTENT_PLANNER=
# PAYLABS_TUTOR_MODEL_INTENT_PLANNER=

# ─── RSSHub / Source Feed Bootstrap ───────────────────────
PAYLABS_RSSHUB_ENABLED=true
PAYLABS_RSSHUB_SYNC_SECRET=
PAYLABS_RSSHUB_ADMIN_SECRET=
PAYLABS_RSSHUB_BASE_URL=https://rsshub.rssforever.com
PAYLABS_RSSHUB_FALLBACK_BASE_URLS=
PAYLABS_RSSHUB_MAX_ITEMS_PER_ROUTE=25

# ─── Source Seed ──────────────────────────────────────────
PAYLABS_SOURCE_SEED_TOKEN=
PAYLABS_PLATFORM_WALLET=
PAYLABS_TREASURY_WALLET=

# ─── Circle SDK ───────────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# HMAC secret for agent context signing (generate: openssl rand -hex 32)
# Never log, never expose to client, never commit real value
PAYLABS_HMAC_SECRET=

# ─── Circle DCW Wallet IDs (managed outside app) ─────────
PAYLABS_TREASURY_WALLET_ID=
PAYLABS_TREASURY_WALLET_ADDRESS=
PAYLABS_RESERVE_WALLET_ID=
PAYLABS_RESERVE_WALLET_ADDRESS=

# ─── Circle UCW (User-Controlled Wallets) ────────────────
# NEXT_PUBLIC_CIRCLE_APP_ID=     # App ID from Circle Console
# CIRCLE_API_KEY=                 # Same as above, for UCW backend calls

# ─── Payment Executor (optional, for backend executor) ────
PAYLABS_PAYMENT_EXECUTOR_URL=
PAYLABS_PAYMENT_EXECUTOR_API_KEY=
PAYLABS_PAYMENT_ROUTE=none
PAYLABS_PAYMENT_EXECUTOR=noop

# ─── Debug (optional) ────────────────────────────────────
# PAYLABS_LLM_DEBUG=true
# NEXT_PUBLIC_PAYLABS_UCW_DEBUG=1
