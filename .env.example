# PayLabs - Lepton Agents Hackathon 2026
# Copy to .env.local and fill real values. Never commit .env.local.

NEXT_PUBLIC_PAYLABS_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

SUPABASE_SERVICE_ROLE_KEY=

PAYLABS_SOURCE_SEED_TOKEN=
PAYLABS_PLATFORM_WALLET=
PAYLABS_TREASURY_WALLET=
PAYLABS_CREATOR_1_WALLET=
PAYLABS_CREATOR_2_WALLET=
PAYLABS_HMAC_SECRET=
PAYLABS_MAX_LESSON_PRICE_USDC=0.05

# Circle Gateway x402
X402_GATEWAY_ENABLED=true
X402_GATEWAY_NETWORK=arc-testnet
X402_RECEIVER_ADDRESS=
CIRCLE_GATEWAY_API_KEY=

# ─── RSSHub / Source Feed Bootstrap ───────────────────────
PAYLABS_RSSHUB_ENABLED=true
PAYLABS_RSSHUB_SYNC_SECRET=
PAYLABS_RSSHUB_DEFAULT_BASE_URL=https://rsshub.app
PAYLABS_RSSHUB_MAX_ITEMS_PER_ROUTE=25

# ─── Per-Agent LLM Routing ────────────────────────────────
# If all agents should use the same model, only DEFAULT values are required.
# Per-agent values override DEFAULT values.
# Agent keys: INTAKE, INTENT, PLANNER, VERIFIER, VERIFIER_SPECIALIST,
#             SPECIALIST_DECISION, POLICY, EXECUTOR

PAYLABS_LLM_REQUIRED=true

# Default LLM config (used by all agents unless overridden per-agent)
PAYLABS_LLM_PROVIDER_DEFAULT=mimo
PAYLABS_LLM_BASE_URL_DEFAULT=https://mimo-api.example/v1
PAYLABS_LLM_API_KEY_DEFAULT=
PAYLABS_TUTOR_MODEL_DEFAULT=mimo-v2.5-pro

# Optional legacy fallback
PAYLABS_OPENAI_API_KEY=
OPENAI_API_KEY=
PAYLABS_TUTOR_MODEL=

# Optional per-agent overrides (uncomment and fill to route specific agents differently)
# PAYLABS_LLM_PROVIDER_INTAKE=
# PAYLABS_LLM_BASE_URL_INTAKE=
